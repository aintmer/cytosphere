<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required by the Mac App Store: the app must be sandboxed. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- PNG export: write the rendered wallpaper to the location the user
	     picks in the save panel. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!-- StoreKit / in-app purchase networking (product fetch + purchase).
	     The app makes no other outbound connections of its own. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
